{
  "name": "balotachain",
  "private": true,
  "description": "BalotaChain monorepo root — coordinates Tauri TypeScript workspaces. Flutter, Rust, and Go packages are managed by their own toolchains.",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "lint": "eslint . --ext .js,.mjs,.cjs,.ts,.tsx --no-error-on-unmatched-pattern",
    "format:check": "prettier --check --no-error-on-unmatched-pattern \"eslint.config.mjs\" \"package.json\" \"pnpm-lock.yaml\" \".github/workflows/*.{yml,yaml}\" \"apps/**/*.{js,mjs,cjs,ts,tsx,json,yml,yaml}\"",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "build": "pnpm -r --if-present build"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "eslint": "^9.27.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1"
  }
}
